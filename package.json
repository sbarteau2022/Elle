{
  "name": "elle",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "ELECTRON=true vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w headphone_motion"
  },
  "dependencies": {
    "jsdom": "^29.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "node-addon-api": "^8.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "org.observerfoundation.elleai",
    "productName": "Elle",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/addons/headphone-motion/build/Release/headphone_motion.node"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "minimumSystemVersion": "11.0",
      "extendInfo": {
        "NSMotionUsageDescription": "Elle uses AirPods Pro motion sensors to provide spatial presence context during conversations."
      }
    },
    "dmg": {
      "title": "Elle"
    }
  }
}
