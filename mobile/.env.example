# Elle door — environment. Copy to .env (gitignored). None of these are
# secrets — OAuth client IDs are public identifiers — but they're per-project,
# so the example ships placeholders.

# Worker origin (defaults to the deployed elle-worker when unset).
# EXPO_PUBLIC_ELLE_WORKER_URL=https://elle-worker.sbarteau2022.workers.dev

# ── Google sign-in (see README → "Google sign-in") ──────────────────────────
# All three come from one Google Cloud project's OAuth credentials.
# Unset ⇒ the Google button simply doesn't render; email/password still works.

# The WEB application client ID (yes, web — it's the idToken audience on Android
# and what the worker's GOOGLE_CLIENT_ID allowlist must contain).
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=1234567890-abc.apps.googleusercontent.com

# The IOS application client ID.
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=1234567890-def.apps.googleusercontent.com

# The iOS client ID REVERSED (Google Cloud Console shows it as "iOS URL scheme").
# Build-time only — wires the URL scheme into the iOS app at prebuild.
# GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.1234567890-def
