# Elle — environment variables
# Copy to .env for local development

# Cloudflare Worker (required)
VITE_ELLE_WORKER_URL=https://elle-worker.sbarteau2022.workers.dev

# Auth is a per-user superadmin JWT obtained at runtime via the login screen
# (POST /api/elle-auth on elle-worker) — same flow as elle-dev-console.
# No service key or build-time credential is needed.