# Supabase project URL (e.g. https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key
VITE_SUPABASE_ANON_KEY=

# Set to "true" to route all API calls to a local Ollama instance instead of Supabase
VITE_SOVEREIGN=false

# Ollama base URL (only used when VITE_SOVEREIGN=true)
VITE_OLLAMA_URL=http://localhost:11434

# Ollama model name (only used when VITE_SOVEREIGN=true)
VITE_OLLAMA_MODEL=mistral
