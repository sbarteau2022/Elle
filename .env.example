# ============================================================
# ELLE PLATFORM — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
# ============================================================

# ── SOVEREIGN MODE TOGGLE ───────────────────────────────────
#
#   false  →  Cloud / Public-facing mode
#              Routes all API calls to Supabase Edge Functions.
#              Requires VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY.
#
#   true   →  Sovereign / Local Elle mode
#              Routes all API calls to your local Ollama instance.
#              No Supabase connection needed. Auth is bypassed.
#
VITE_SOVEREIGN=false

# ── CLOUD (VITE_SOVEREIGN=false) ────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── SOVEREIGN (VITE_SOVEREIGN=true) ─────────────────────────
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=mistral
