# Elle — environment variables
# Copy to .env for local development

# Cloudflare Worker (required)
VITE_ELLE_WORKER_URL=https://elle.sbarteau2022.workers.dev
VITE_ELLE_SERVICE_KEY=<from Cloudflare Dashboard: Workers > elle > Settings > Variables>

# Sovereign local mode (optional — routes to Ollama instead of worker)
VITE_SOVEREIGN=false
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=mistral